# ── Slack ──────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-your-bot-token

# Socket Mode (local / server deployments) — omit for Lambda/HTTP mode
SLACK_APP_TOKEN=xapp-your-app-level-token

# HTTP mode (Lambda) — omit for Socket Mode
# SLACK_SIGNING_SECRET=your-signing-secret

# ── GitHub ─────────────────────────────────────────────
# Personal access token (classic) with repo scope,
# OR a fine-grained token with Issues read/write + Projects read/write
GITHUB_TOKEN=ghp_your_token_here

# GitHub org or user that owns the repos you want to file issues against
GITHUB_OWNER=your-org-or-username

# Optional: comma-separated list of repos to show (leave blank to load all from GITHUB_OWNER)
# GITHUB_REPOS=frontend,backend,infra

# Optional: default project name to pre-select in the modal (must match the project title exactly)
# DEFAULT_GITHUB_PROJECT=My Project
